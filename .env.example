# ========================================
# متغيرات البيئة — Deer Books Bot
# انسخ هذا الملف إلى .env وأدخل قيمك
# ========================================

# توكن البوت من @BotFather
BOT_TOKEN=your_bot_token_here

# معرف حساب المدير (Telegram User ID)
ADMIN_ID=your_telegram_user_id_here

# رابط الـ Webhook (يُضبط تلقائياً على Koyeb)
# مثال: https://my-bot.koyeb.app
WEBHOOK_URL=https://your-domain.koyeb.app

# المنفذ (تلقائي على Koyeb)
PORT=5000
